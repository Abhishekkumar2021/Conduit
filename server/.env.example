# Conduit Server — Environment variables
# Copy to .env and fill in production values

CONDUIT_SECRET_KEY=change-me-in-production
CONDUIT_DB_HOST=localhost
CONDUIT_DB_PORT=5432
CONDUIT_DB_USER=conduit
CONDUIT_DB_PASSWORD=conduit
CONDUIT_DB_NAME=conduit
CONDUIT_TEST_DB_URL=postgresql+asyncpg://conduit:conduit123@127.0.0.1:5432/conduit_test
CONDUIT_REDIS_HOST=localhost
CONDUIT_REDIS_PORT=6379
CONDUIT_DEBUG=true
